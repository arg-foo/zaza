# Optional API keys — core tools (yfinance, SEC EDGAR) require no keys

# Enables get_social_sentiment (Reddit)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Enables get_economic_calendar (FRED)
FRED_API_KEY=

# Docker binary path for PKScreener (auto-detected if not set)
DOCKER_PATH=

# --- Zaza MCP Transport ---
# Set to "streamable-http" to serve over HTTP (required for consumer)
ZAZA_MCP_TRANSPORT=streamable-http
ZAZA_MCP_HOST=0.0.0.0
ZAZA_MCP_PORT=8100

# --- Trade Execution Consumer (python -m zaza_consumer) ---
# Required
REDIS_URL=redis://localhost:6379/0
TIGER_MCP_URL=http://localhost:8000/mcp
ZAZA_MCP_URL=http://localhost:8100/mcp

# Optional (defaults shown)
CONSUMER_GROUP=trade-executor
CONSUMER_NAME=executor-1
RTH_SCAN_INTERVAL=300
ORDER_DELAY_MS=500
XREAD_BLOCK_MS=5000
XREAD_COUNT=10
